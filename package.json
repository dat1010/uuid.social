{
  "name": "uuid-social",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && vite preview",
    "test": "vitest run --config vitest.config.ts",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply uuid-social-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply uuid-social-db --remote",
    "postinstall": "wrangler types"
  },
  "dependencies": {
    "daisyui": "^5.5.23",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.10.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@react-router/dev": "^7.10.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.100.0"
  }
}
